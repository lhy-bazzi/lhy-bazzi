# UniAI Python AI Service — Environment Variables
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# ---- Runtime Environment ----
# Options: dev | test | prod
UNI_AI_ENV=dev

# ---- LLM API Keys ----
# DashScope (Qwen LLM + Embedding) — Required for default config
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: additional LLM providers (activate in configs/config.yaml)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ---- PostgreSQL ----
UNI_AI__DATABASE__URL=postgresql+asyncpg://postgres:postgres@localhost:5432/uni_ai

# ---- Redis ----
UNI_AI__REDIS__URL=redis://localhost:6379/0

# ---- MinIO ----
UNI_AI__MINIO__ENDPOINT=localhost:9000
UNI_AI__MINIO__ACCESS_KEY=minioadmin
UNI_AI__MINIO__SECRET_KEY=minioadmin

# ---- Milvus ----
UNI_AI__MILVUS__HOST=localhost
UNI_AI__MILVUS__PORT=19530

# ---- Elasticsearch ----
# (nested list not easily set via env — use configs/config.yaml for hosts)

# ---- RabbitMQ ----
UNI_AI__MQ__URL=amqp://guest:guest@localhost:5672/

# ---- Embedding / Reranker Device ----
# Use "cuda" for GPU acceleration, "cpu" for CPU-only environments
UNI_AI__EMBEDDING__DEVICE=cpu
UNI_AI__RERANKER__DEVICE=cpu

# ---- HuggingFace Mirror (Optional) ----
# Uncomment if HuggingFace is unreachable (e.g. mainland China)
# HF_ENDPOINT=https://hf-mirror.com
